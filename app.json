{
  "expo": {
    "name": "Housie",
    "slug": "housie-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "light",
    "scheme": "housie",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "androidStatusBar": {
      "translucent": false
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.praveen.housie",
      "associatedDomains": [
        "applinks:housie-155ea.web.app",
        "applinks:housie-155ea.firebaseapp.com"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e",
        "foregroundImage": "./assets/logo.png",
        "backgroundImage": "./assets/logo.png",
        "monochromeImage": "./assets/logo.png"
      },
      "package": "com.praveen.housie",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "housie-155ea.web.app",
              "pathPrefix": "/multiplayer"
            },
            {
              "scheme": "https",
              "host": "housie-155ea.firebaseapp.com",
              "pathPrefix": "/multiplayer"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/logo.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d4725ae5-4246-4a3a-b3ce-1046560439c6"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/d4725ae5-4246-4a3a-b3ce-1046560439c6"
    }
  }
}
