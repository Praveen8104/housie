{
  "expo": {
    "name": "Housie",
    "slug": "housie-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "light",
    "scheme": "housie",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "androidStatusBar": {
      "translucent": false
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e",
        "foregroundImage": "./assets/logo.png",
        "backgroundImage": "./assets/logo.png",
        "monochromeImage": "./assets/logo.png"
      },
      "package": "com.praveen.housie"
    },
    "web": {
      "favicon": "./assets/logo.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c6bb28ad-28ef-4b11-9716-db19685e1b17"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/c6bb28ad-28ef-4b11-9716-db19685e1b17"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
